# DeepSeek API Key (for AI exam paper analysis)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Turso cloud database (get from turso.tech)
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=your-turso-token

# PayJS payment config (get from payjs.cn)
PAYJS_MERCHANT_ID=your-merchant-id
PAYJS_KEY=your-payjs-key

# Site URL (set after deployment)
SITE_URL=https://your-app.vercel.app